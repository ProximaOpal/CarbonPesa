# CarbonPesa Backend — Environment Variables
# Copy this file to .env and fill in your real keys.
# NEVER commit the .env file to version control.

# ── DATABASE ─────────────────────────────────────────────────────────
# PostgreSQL + PostGIS connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost/carbonpesa

# ── GOOGLE EARTH ENGINE ──────────────────────────────────────────────
# Path to your GEE Service Account JSON key file
GEE_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com
GEE_KEY_FILE=gee-key.json

# ── AFRICA'S TALKING ─────────────────────────────────────────────────
# Get from: https://account.africastalking.com/
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key

# ── SAFARICOM DARAJA API ──────────────────────────────────────────────
# Get from: https://developer.safaricom.co.ke/
DARAJA_CONSUMER_KEY=your_daraja_consumer_key
DARAJA_CONSUMER_SECRET=your_daraja_consumer_secret
DARAJA_INITIATOR_NAME=your_initiator_name
DARAJA_INITIATOR_PASSWORD=your_initiator_password
DARAJA_SHORTCODE=600000
DARAJA_ENV=sandbox
# B2C callback URLs (replace with your public API URL)
DARAJA_TIMEOUT_URL=https://api.carbonpesa.com/b2c/timeout
DARAJA_RESULT_URL=https://api.carbonpesa.com/b2c/result

# ── HEDERA HASHGRAPH ─────────────────────────────────────────────────
# Get from: https://portal.hedera.com/
HEDERA_ACCOUNT_ID=0.0.XXXXXXXX
HEDERA_PRIVATE_KEY=302e020100300506032b657004220420...
HEDERA_TOPIC_ID=0.0.XXXXXXXX
HEDERA_ENV=testnet
